# daily-driver workspace configuration
#
# Structured settings live here; narrative prose stays in Markdown
# (context.md, voice-profile.md). The schema is strict (extra="forbid")
# at every level, so a typo like `tracer:` fails loudly.
#
# To enable a commented block, uncomment the header (column 0) AND every
# nested line together. Uncommenting a lone inner field silently nests it
# under whichever block is open above, and Pydantic rejects it.

# Required: workspace settings.
daily_driver:
  # Where command output (jobs.csv, daily/, etc.) lives. Relative paths
  # resolve against the workspace root.
  output_dir: .

# Optional: personal context surfaced into Claude prompts.
# user_profile:
#   name: ""
#   citizenship: []  # ["US", "CA"]
#   work_auth: {}  # {"US": "citizen", "CA": "PR"}
#   timezone: ""  # "America/Vancouver"
#   seeking_since: 2026-04-06  # YYYY-MM-DD when active job search began

# Required: tracker configuration.
tracker:
  default_category: task
  # Warn (stderr, one-time) when --status is outside the recommended set
  # (open, in-progress, blocked, done, ruled-out). The entry still saves.
  # warn_unknown_status: true
  # Extra recommended statuses, added to the built-ins above. These never
  # trigger warn_unknown_status. Spelling is normalized (case-folded,
  # underscores -> hyphens), so `ruled_out` == `ruled-out`.
  # extra_statuses: [waiting, snoozed]
  # Extra terminal statuses, merged with the built-ins (done, ruled-out,
  # dropped, rejected, closed). Terminal entries are excluded from stalled
  # detection and follow-ups. Built-ins cannot be removed.
  # terminal_statuses: [cancelled]
  categories:
    task:
      required: [title]
    # Add more categories as needed. `required` lists fields that must
    # be set on `tracker add`.
    # errand:
    #   required: [title]
    # ticket:
    #   required: [title, link]

# Optional: recurring tasks surfaced into day-start planning.
# recurring_tasks:
#   - name: "Review tracker follow-ups"
#     cadence: daily            # daily | weekly | monthly
#     estimated_minutes: 10
#   - name: "Weekly retro"
#     cadence: weekly
#     day: friday            # only valid when cadence is weekly

# Optional: check-in / jobs scheduler (consumed by `scheduler install`).
# `checkin.times` is a list of HH:MM; `jobs.time` is one HH:MM. Each
# job takes an optional `days`: "daily" (default), "weekdays", or a
# day list. day-start / day-end cadence lives in the separate
# `schedule:` block below.
# scheduler:
#   checkin:
#     times:
#       - "11:00"
#       - "15:00"
#     days: "weekdays"
#
#   jobs:
#     time: "07:00"
#     days: [sun, wed]

# Optional: day-start / day-end scheduled times (HH:MM, 24h). When set,
# `scheduler install` fires those jobs; `days` narrows both ("weekdays"
# or a day list, default daily). Also the single source of truth for
# `is_late_day`. Leave unset to skip the scheduled run.
# schedule:
#   day_start: "08:00"
#   day_end: "17:30"
#   days: "weekdays"

# Optional: claude session behavior.
# claude:
#   # When true, `check-in` resumes the workspace's most recent claude
#   # session instead of opening a fresh one.
#   resume_check_in: false

# Optional: AI provider routing for headless tasks (summary,
# voice-update, job_search enrichment) plus the shared claude/ollama
# connection blocks. Interactive launchers (day-start, check-in,
# day-end) always use claude. Omit the block to keep claude defaults.
#
# Resolution chain for any task: per-task/phase -> domain default ->
# global `ai.provider` -> claude. Provider and model are chosen
# independently, so a model must be valid for whatever provider it
# lands on (claude: "sonnet"; ollama: a tag like "qwen2.5:14b").
# ai:
#   # Global fallback provider for every routable task (summary,
#   # voice_update, job_search enrichment). Set to `ollama` to route the
#   # whole app in one line; per-task blocks still override.
#   provider: claude
#   # Global fallback model, used when neither the task block nor a domain
#   # default names one. Chosen independently of provider, so it must match
#   # whichever provider a task resolves to.
#   # model: sonnet
#
#   summary:
#     # claude | ollama. Unset inherits the resolution chain (domain
#     # default -> ai.provider -> claude); set to pin this task.
#     provider: claude
#     # Provider-specific model id (claude: "sonnet"; ollama: a pulled tag
#     # like "qwen2.5:14b"). Chosen independently of provider, so it must
#     # match whichever provider this task resolves to.
#     # model: sonnet
#
#   # Provider / model routing for the `voice-update` task.
#   voice_update:
#     # claude | ollama. Unset inherits the resolution chain (domain
#     # default -> ai.provider -> claude); set to pin this task.
#     provider: claude
#     # Provider-specific model id (claude: "sonnet"; ollama: a pulled tag
#     # like "qwen2.5:14b"). Chosen independently of provider, so it must
#     # match whichever provider this task resolves to.
#     # model: sonnet
#
#   # Interactive launchers (day-start, day-end, check-in) always run on
#   # claude, so this block is model-only (no provider knob). A `--model`
#   # flag overrides it.
#   interactive:
#     # Claude model ("sonnet", "haiku", "opus"). Unset lets the claude CLI
#     # pick its default. A `--model` flag overrides this.
#     model: sonnet
#
#   # Only consulted when a task is routed to the claude provider.
#   claude:
#     # Worker threads for parallel enrichment. 1 forces serial.
#     max_parallel: 4
#
#   # Only consulted when a task is routed to the ollama provider.
#   ollama:
#     endpoint: "http://localhost:11434"
#     # Ollama is materially slower than the claude API; give it room.
#     timeout: 60
#     max_parallel: 4

# Optional: focus mode defaults.
# focus:
#   # Fallback duration when `focus on` runs without `--for`
#   # (same suffixes as --for: "25m", "1h", "90m").
#   default_duration: "25m"

# Optional: gather config (controls what `daily-driver gather <kind>` reads).
# gather:
#   git:
#     # Directories to scan for git activity (absolute or tilde-prefixed).
#     # Each holds one or more git checkouts.
#     search_paths:
#       - "~/git"

# Optional: write daily-plan time blocks to a local macOS Calendar
# (consumed by `calendar sync`, macOS-only).
# calendar:
#   # Opt-in switch for `calendar sync`; false makes sync a clean no-op.
#   sync_enabled: false
#   # Local macOS Calendar to write into; must already exist in Calendar.app.
#   plan_calendar_name: "Daily Plan"

# Optional: plugins. Each plugin schema is strict — typos error out.
# plugins:
#   job_search:
#     persona: "Senior SRE / Platform Engineer"
#     roles: []  # ["SRE", "Platform Engineer"]
#     domain_keywords: []  # ["kubernetes", "observability"]
#     seniority_keywords: []  # ["senior", "staff", "principal"]
#
#     locations:
#       home_city: "Vancouver, BC"
#       remote: true
#       # When true, remote roles from ANY country pass (country-blind). When
#       # false (default), a remote role passes only if its location names a
#       # country in `countries` (or names no country at all); a remote role
#       # that names an unlisted country is dropped.
#       remote_unlisted_countries: false
#       # ISO code -> city allow-list. Empty list = anywhere in that country;
#       # a non-empty list narrows to ONLY those cities. Remote roles pass when
#       # `remote` is true, scoped to these countries unless
#       # `remote_unlisted_countries` is set.
#       countries:
#         CA: [Vancouver, Victoria]
#         US: []
#
#     scraper:
#       enabled: false
#       # Retries for HTTP 429/503. Honors Retry-After, else exponential
#       # backoff (1.5s, 3s, 6s, ... capped at 30s). 0 disables.
#       max_retries: 3
#       # Max posting age in days. Applied to hn_jobs (17k+ Algolia history);
#       # other sources are implicitly recent. 0 disables.
#       max_age_days: 30
#       # User-Agent header sent by the HTTP/RSS scrapers.
#       user_agent: "Mozilla/5.0 (Macintosh; Intel Mac OS X 10.15; rv:128.0) Gecko/20100101 Firefox/128.0"
#       # Per-source HTTP / browser timeout, in seconds.
#       timeout: 30
#       # Override search terms for query-based sources (JobSpy, Apple).
#       # Unset derives them from roles and keywords.
#       search_terms: null
#       # Worker threads for the parallel (headless) scrape phase.
#       parallel_workers: 8
#       # Pagination / scroll passes per search term (Apple, JobSpy).
#       max_pages: 3
#       # Playwright engine for browser sources (Apple): firefox, chromium,
#       # or webkit. Must be installed (`playwright install <engine>`).
#       browser: firefox
#
#     # Post-scrape LLM pass adding a fit score and Notes summary. Costs
#     # API calls; max_enrich_fit caps how many run.
#     enrichment:
#       # Domain default provider for enrichment. Unset inherits `ai.provider`,
#       # then claude. The per-phase block overrides it.
#       provider: claude
#       # Provider-specific model id (claude: "sonnet"; ollama: a tag like
#       # "qwen2.5:14b"). Chosen independently of provider, so it must match
#       # whichever provider a phase resolves to.
#       # model: sonnet
#
#       # Route override for the fit/notes pass (one call per job).
#       fit_notes:
#         # claude | ollama. Unset inherits the enrichment domain default,
#         # then `ai.provider`, then claude.
#         provider: claude
#         # Provider-specific model id (claude: "sonnet"; ollama: a tag like
#         # "qwen2.5:7b"). Chosen independently of provider, so it must match
#         # whichever provider this phase resolves to.
#         # model: sonnet
#       # Seconds before a single enrichment LLM call is abandoned.
#       enrich_timeout: 30
#       # Score each job 1-10 for fit.
#       enrich_fit: true
#       # One-line Notes summary (stack, remote, red flags).
#       enrich_notes: true
#       # Judge remote/hybrid/onsite (no extra LLM call).
#       enrich_is_remote: true
#       # Cap on fit/notes LLM calls per run (bounds API cost).
#       max_enrich_fit: 50
#       # Under `backfill --force-update`, skip rows enriched within N hours
#       # so an interrupted run resumes. 0 = re-enrich every active row;
#       # `missing` = only rows with no enrichment timestamp yet.
#       force_recook_cooldown_hours: 24
#       # Pause between detail-page fetches, in seconds.
#       detail_delay_seconds: 0.5
#       # Extra assessments per job description. Each appends a
#       # "Label: value" to Notes. `assess` is a natural-language instruction
#       # the LLM reasons about, not a keyword match.
#       criteria:
#         - label: Sponsorship
#           assess: "Does the role offer visa sponsorship?"
#
#     # `jobs verify` liveness checks for sources without full board
#     # listings (board-backed rows verify by board-diff each run).
#     verify:
#       # Re-check a row's URL when its last liveness evidence (Date
#       # Verified, else Date Found) is at least this many days old.
#       reverify_days: 7
#       # Rows with no checkable URL (indeed bot wall, HN permalinks) close as
#       # age-unverified once last evidence (Date Verified, refreshed by
#       # re-sightings, else Date Found) is this old. Generous by design; a
#       # re-found posting reopens loudly.
#       unverified_age_days: 30
#     sources:
#
#       # All keys optional; omitted = enabled (SourceToggle default).
#       # Set a key to `false` to disable it.
#       #
#       # Shipped scrapers (HTTP/RSS, no extra deps):
#       remoteok:            # remoteok.com RSS
#         enabled: false
#         # Tag slugs queried alongside the unfiltered feed, each as
#         # remoteok.com/api?tags=<slug>. The newest-100 feed is thin per role, so
#         # tags surface relevant postings. Unknown tags harmlessly return the
#         # unfiltered feed (deduped). Empty = feed only.
#         remoteok_tags: [devops, kubernetes, aws]
#       weworkremotely:            # weworkremotely.com listings
#         enabled: false
#         # Category slugs, e.g. "devops-sysadmin" ->
#         # /categories/remote-devops-sysadmin-jobs.rss. Empty scrapes nothing;
#         # this source needs at least one.
#         wwr_categories: []
#       hn_who_is_hiring:            # HN monthly "Who is hiring?" thread
#         enabled: false
#         hn_max_posts: 500
#       hn_jobs:            # HN curated jobs (YC-funded company posts)
#         enabled: false
#         hn_max_posts: 500
#       greenhouse:            # Greenhouse boards (configurable list)
#         enabled: false
#         # Slugs always scraped (the "<slug>" in boards.greenhouse.io/<slug>),
#         # unioned with the discover-boards matched cache.
#         greenhouse_boards: [anthropic]
#         # Slugs NEVER scraped, even if pinned or discovered. Matched exactly
#         # incl. case: to silence Notion, write Notion not notion.
#         exclude_boards: []
#       ashby:            # AshbyHQ boards (configurable list)
#         enabled: false
#         # Slugs always scraped (the "<slug>" in jobs.ashbyhq.com/<slug>),
#         # unioned with the discover-boards matched cache. Case-sensitive.
#         ashby_boards: []
#         # Slugs NEVER scraped, even if pinned or discovered. Matched exactly
#         # incl. case: to silence Notion, write Notion not notion.
#         exclude_boards: []
#       lever:            # Lever boards (configurable list)
#         enabled: false
#         # Slugs always scraped (the "<slug>" in jobs.lever.co/<slug>),
#         # unioned with the discover-boards matched cache.
#         lever_boards: []
#         # Slugs NEVER scraped, even if pinned or discovered. Matched exactly
#         # incl. case: to silence Notion, write Notion not notion.
#         exclude_boards: []
#       workable:            # Workable accounts (configurable list)
#         enabled: false
#         # Account slugs (the "<slug>" in apply.workable.com/<slug>). Each
#         # account's full list is fetched in one request.
#         workable_accounts: []
#       workday:            # Workday careers sites (configurable list)
#         enabled: false
#         # Each site named by the three URL parts. For
#         # crowdstrike.wd5.myworkdayjobs.com/crowdstrikecareers that is
#         # tenant=crowdstrike, host=wd5, site=crowdstrikecareers. Optional `company`
#         # overrides the display name (default: title-cased tenant).
#         workday_boards:
#         - tenant: crowdstrike
#           host: wd5
#           site: crowdstrikecareers
#           company: CrowdStrike
#
#       # Shipped scrapers (Playwright, needs `playwright install`):
#       apple: false            # jobs.apple.com (API intercept)
#
#       # LinkedIn + Indeed (JobSpy, needs python-jobspy>=1.1.82). Each
#       # site is fetched separately under its own progress row.
#       # `country` (Indeed only) sets the regional host and is the
#       # fallback for unrecognized countries.
#       linkedin:
#         enabled: true
#         results_wanted_per_query: 50
#         hours_old: 168
#       indeed:            # indeed.com (country sets the regional host)
#         enabled: true
#         results_wanted_per_query: 50
#         hours_old: 168
#         country: USA
