# daily-driver workspace configuration
#
# Structured settings live here; narrative prose stays in Markdown files
# (context.md, voice-profile.md). The schema is strict everywhere:
# the root model is `extra="forbid"`, as is every nested block (including
# plugins). Unknown keys raise a validation error so typos like `tracer:`
# for `tracker:` fail loudly. Per-entry user data belongs under
# `tracker.extras`; per-category fields under `tracker.categories.<name>`;
# narrative context in `voice-profile.md` or a sibling `.notes.md`.
#
# To enable a commented block: uncomment the header (at column 0) AND
# every nested line together. Don't uncomment a single inner field on
# its own — YAML will silently nest it inside whichever open block is
# above, and Pydantic will reject it as `extra_forbidden`.

# Required: workspace settings.
daily_driver:
  # Where command output (jobs.csv, daily/, etc.) lives. Relative paths
  # resolve against the workspace root.
  output_dir: .

# Optional: personal context surfaced into Claude prompts.
# user_profile:
#   name: ""
#   citizenship: []  # ["US", "CA"]
#   work_auth: {}  # {"US": "citizen", "CA": "PR"}
#   timezone: ""  # "America/Vancouver"
#   seeking_since: 2026-04-06  # YYYY-MM-DD when active job search began

# Required: tracker configuration.
tracker:
  default_category: task
  # Print a stderr nudge when `tracker add/update --status` is given a
  # value outside the recommended set (open, in-progress, blocked, done,
  # ruled-out). Entries still save with the custom status; the warning
  # is a one-time hint. Set to false to silence.
  # warn_unknown_status: true
  # Extra status values to add to the tracker's recommended set, on top
  # of the built-ins (open, in-progress, blocked, done, ruled-out). Values
  # here never trigger the `warn_unknown_status` nudge. Spelling is
  # normalized (case-folded, underscores -> hyphens), so `ruled_out` and
  # `ruled-out` are the same status.
  # extra_statuses: [waiting, snoozed]
  categories:
    task:
      required: [title]
    # Add more categories as you need them. `required` lists fields that
    # must be set on `tracker add`.
    # errand:
    #   required: [title]
    # ticket:
    #   required: [title, link]

# Optional: recurring tasks surfaced into day-start planning.
# recurring_tasks:
#   - name: "Review tracker follow-ups"
#     cadence: daily            # daily | weekly | monthly
#     estimated_minutes: 10
#   - name: "Weekly retro"
#     cadence: weekly
#     day: friday            # only valid when cadence is weekly

# Optional: scheduler config (consumed by `scheduler install`).
# `checkin.times` is a list of HH:MM strings; `jobs.time` is a single
# HH:MM string. Unknown keys are rejected. NOTE: `day_start` /
# `day_end` cadence does NOT live here — it lives in the separate
# top-level `schedule:` block below as HH:MM strings (the single
# source of truth for those two jobs).
# scheduler:
#   checkin:
#     times:
#       - "11:00"
#       - "15:00"
#   jobs:
#     time: "07:00"

# Optional: day-start / day-end scheduled times (HH:MM, 24h).
# When set, `scheduler install` adds launchd jobs that fire `day-start` /
# `day-end` at these times. Leave unset to skip the scheduled run. This
# is also read by `is_late_day` evaluation — single source of truth.
# schedule:
#   day_start: "08:00"
#   day_end: "17:30"

# Optional: claude session behavior.
# claude:
#   # When true, `check-in` resumes the prior `claude` session instead of
#   # opening a fresh one. Useful if you keep one long-running session per
#   # day and want check-in to land in it.
#   resume_check_in: false

# Optional: AI provider routing for the headless `summary` task,
# plus the shared claude/ollama provider-connection blocks (also
# consulted by `plugins.job_search.enrichment` routing).
# Interactive launchers (day-start, check-in, day-end) always use claude —
# they need session resume / agents / workspace context that Ollama lacks.
# Omitting the entire block keeps claude defaults for summary.
# ai:
#   summary:
#     # provider: claude | ollama
#     provider: claude
#     # Provider-specific model identifier. For claude: "sonnet", "haiku",
#     # etc. For ollama: a pulled tag like "qwen2.5:14b" or "phi4".
#     # model: sonnet
#   # Only consulted when a task is routed to the claude provider.
#   claude:
#     # Worker threads for parallel enrichment. 1 forces serial.
#     max_parallel: 4
#   # Only consulted when a task is routed to the ollama provider.
#   ollama:
#     endpoint: "http://localhost:11434"
#     # Ollama is materially slower than the claude API; give it room.
#     timeout: 60
#     max_parallel: 4

# Optional: focus mode defaults.
# focus:
#   # Fallback duration when `focus on` runs without `--for`.
#   # Accepts the same suffixes as `--for` (e.g. "25m", "1h", "90m").
#   default_duration: "25m"

# Optional: gather config (controls what `daily-driver gather <kind>` reads).
# gather:
#   git:
#     # Repos to scan for `gather git` activity. Each entry is a directory
#     # containing one or more git checkouts. Paths can be absolute or
#     # tilde-prefixed.
#     search_paths:
#       - "~/git"

# Optional: plugins. Each plugin schema is strict — typos error out.
# plugins:
#   job_search:
#     persona: "Senior SRE / Platform Engineer"
#     roles: []  # ["SRE", "Platform Engineer"]
#     domain_keywords: []  # ["kubernetes", "observability"]
#     seniority_keywords: []  # ["senior", "staff", "principal"]
#     locations:
#       home_city: "Vancouver, BC"
#       remote: true
#       countries: [CA, US]
#     scraper:
#       enabled: false
#       # Retries for HTTP 429/503 responses (rate limits). Honors the
#       # Retry-After header when present; otherwise applies exponential
#       # backoff (1.5s, 3s, 6s, ... capped at 30s). Set to 0 to disable.
#       max_retries: 3
#       # Maximum age (in days) for scraped postings. Currently applied to
#       # `hn_jobs` (which has 17k+ historical entries via Algolia). Set to
#       # 0 to disable the filter. Other sources are implicitly recent.
#       max_age_days: 30
#       # User-Agent header sent by the HTTP/RSS scrapers.
#       user_agent: "Mozilla/5.0 (Macintosh; Intel Mac OS X 10.15; rv:128.0) Gecko/20100101 Firefox/128.0"
#       # Per-source HTTP / browser timeout, in seconds.
#       timeout: 30
#       # Override the search terms sent to query-based sources (JobSpy,
#       # Apple). When unset, terms are derived from roles and keywords.
#       search_terms: null
#       # Worker threads for the parallel (headless) scrape phase.
#       parallel_workers: 8
#       # Pagination / scroll passes per search term (Apple, JobSpy).
#       max_pages: 3
#       # Playwright engine for browser-driven sources (Apple). One of
#       # firefox, chromium, webkit. The chosen engine must be installed
#       # (`playwright install <engine>`).
#       browser: firefox
#     # Post-scrape enrichment: optional LLM passes that add Product,
#     # Glassdoor rating, a fit score, and a Notes summary. Each pass
#     # costs API calls; the max_* values cap how many run.
#     enrichment:
#       # provider: claude | ollama
#       provider: claude
#       # Provider-specific model identifier. For claude: "sonnet", "haiku",
#       # etc. For ollama: a pulled tag like "qwen2.5:14b" or "phi4".
#       # model: sonnet
#       # Seconds before a single enrichment LLM call is abandoned.
#       enrich_timeout: 30
#       # Cap on company-description lookups per run (bounds API cost).
#       max_enrich_companies: 50
#       # Look up a one-line Product/Purpose summary for each company.
#       enrich_product: true
#       # Look up each company's Glassdoor rating during enrichment.
#       enrich_gd_rating: true
#       # Score each job 1-10 for fit against your persona and locations.
#       enrich_fit: true
#       # Generate a one-line Notes summary (tech stack, remote policy, red flags).
#       enrich_notes: true
#       # Judge each job remote/hybrid/onsite during the fit/notes pass (no extra LLM call).
#       enrich_is_remote: true
#       # Cap on fit/notes LLM calls per run (bounds API cost).
#       max_enrich_fit: 50
#       # Pause between detail-page fetches, in seconds, to avoid rate limits.
#       detail_delay_seconds: 0.5
#       # Extra things to assess in each job description. Each becomes a
#       # "Label: value" segment appended to Notes. `assess` is a
#       # natural-language instruction the LLM reasons about, not a
#       # keyword match.
#       criteria:
#         - label: Sponsorship
#           assess: "Does the role offer visa sponsorship?"
#     sources:
#
#       # All keys are optional; omitted = on (SourceToggle defaults
#       # enabled=true). List a key with `false` to disable it.
#       #
#       # Scrapers shipped in this repo (HTTP/RSS, no extra deps):
#       remoteok: false            # remoteok.com RSS
#       weworkremotely:            # weworkremotely.com listings
#         enabled: false
#         # WeWorkRemotely category slugs to fetch, e.g. "devops-sysadmin"
#         # (becomes /categories/remote-devops-sysadmin-jobs.rss). An empty list
#         # scrapes nothing; this source needs at least one category.
#         wwr_categories: []
#       hn_who_is_hiring:            # HN monthly "Who is hiring?" thread
#         enabled: false
#         hn_max_posts: 500
#       hn_jobs:            # HN curated jobs (YC-funded company posts)
#         enabled: false
#         hn_max_posts: 500
#       greenhouse:            # Greenhouse boards (configurable list)
#         enabled: false
#         # Greenhouse board slugs to scrape (the "<slug>" in
#         # boards.greenhouse.io/<slug>). Each board's full posting list is fetched
#         # in one request; add the companies you are targeting.
#         greenhouse_boards: [anthropic]
#       ashby:            # AshbyHQ boards (configurable list)
#         enabled: false
#         # AshbyHQ board slugs to scrape (the "<slug>" in
#         # jobs.ashbyhq.com/<slug>). Each board's full posting list is fetched in
#         # one request; add the companies you are targeting. Slugs are
#         # case-sensitive (e.g. Notion).
#         ashby_boards: []
#
#       # Scrapers shipped in this repo (Playwright, needs `playwright install`):
#       apple: false            # jobs.apple.com (API intercept)
#
#       # LinkedIn + Indeed (each its own source). Each enabled site
#       # is fetched separately, under its own progress row. country
#       # (Indeed only) sets the regional host and is the fallback for
#       # countries the scraper does not recognize. Requires
#       # `python-jobspy>=1.1.82`.
#       linkedin:
#         enabled: true
#         results_wanted_per_query: 50
#         hours_old: 168
#       indeed:            # indeed.com (country sets the regional host)
#         enabled: true
#         results_wanted_per_query: 50
#         hours_old: 168
#         country: USA
