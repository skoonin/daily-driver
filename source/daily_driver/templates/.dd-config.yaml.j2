# daily-driver workspace configuration
#
# Structured settings live here; narrative prose stays in Markdown files
# (context.md, voice-profile.md). Top-level keys not listed below are
# preserved on parse — the root model is `extra="allow"` so you can stash
# workspace-local notes without a schema bump. Plugin schemas are strict
# (`extra="forbid"`); typos there are real errors.

# Required: workspace settings.
daily_driver:
  # Where command output (jobs.csv, daily/, etc.) lives. Relative paths
  # resolve against the workspace root.
  output_dir: .

# Optional: personal context surfaced into Claude prompts.
# user_profile:
#   name: ""
#   citizenship: []           # ["US", "CA"]
#   work_auth: {}             # {"US": "citizen", "CA": "PR"}
#   timezone: ""              # "America/Vancouver"
#   seeking_since: 2026-04-06  # YYYY-MM-DD when active job search began

# Required: tracker configuration.
tracker:
  default_category: task
  categories:
    task:
      required: [title]
    # Add more categories as you need them. `required` lists fields that
    # must be set on `tracker add`.
    # errand:
    #   required: [title]
    # ticket:
    #   required: [title, link]

# Optional: recurring tasks surfaced into day-start planning.
# recurring_tasks:
#   - name: "Review tracker follow-ups"
#     cadence: daily            # daily | weekly | monthly
#     estimated_minutes: 10
#   - name: "Weekly retro"
#     cadence: weekly
#     day: friday               # only valid when cadence is weekly

# Optional: voice profile hints used by `voice-update` and summary outputs.
# voice_profile:
#   formality: professional-casual    # formal | professional-casual | casual
#   sentence_length: medium           # short | medium | long
#   avoid_words: []
#   preferred_signoff: "—"

# Optional: scheduler config (consumed by `scheduler install`).
# scheduler:
#   check_in:
#     hour: 14
#     minute: 0
#   jobs:
#     hour: 8
#     minute: 30

# Optional: plugins. Each plugin schema is strict — typos error out.
# plugins:
#   job_search:
#     persona: "Senior SRE / Platform Engineer"
#     home_city: "Vancouver, BC"
#     roles: []                     # ["SRE", "Platform Engineer"]
#     domain_keywords: []           # ["kubernetes", "observability"]
#     seniority_keywords: []        # ["senior", "staff", "principal"]
#     min_comp_usd: 180000
#     locations:
#       home_city: "Vancouver, BC"
#       remote: true
#       countries: [CA, US]
#       cities: []
#     compensation:
#       currency: USD               # USD | CAD | EUR | GBP
#       minimum: 180000
#       target: 240000
#     role_filters:
#       exclude_management: true
#       exclude_keywords: []
#     scraper:
#       enabled: false
#       # primary_currency: drop scraped jobs whose parsed comp currency
#       # doesn't match. Unparseable comp passes through. Unset = no filter.
#       # primary_currency: USD            # USD | CAD | EUR | GBP
#       sources:
#         # All keys are optional; omitted = on (SourceToggle defaults
#         # enabled=true). List a key with `false` to disable it.
#
#         # Scrapers shipped in this repo (HTTP/RSS, no extra deps):
#         remoteok: false                  # remoteok.com RSS
#         weworkremotely: false            # weworkremotely.com listings
#         hn_who_is_hiring: false          # HN monthly "Who is hiring?" thread
#         greenhouse: false                # Greenhouse boards (configurable list)
#
#         # Scrapers shipped in this repo (Playwright, needs `playwright install`):
#         apple: false                     # jobs.apple.com (API intercept)
#
#         # python-jobspy aggregator (one toggle, multiple upstream sites;
#         # requires `python-jobspy>=1.1.82`). Internally fetches linkedin +
#         # indeed + google with linkedin_fetch_description=True. Glassdoor
#         # is intentionally disabled in code — JobSpy's Glassdoor path
#         # returns HTTP 400 ("location not parsed") on every request as of
#         # 2026-04. Disable this only if you don't want LinkedIn/Indeed/
#         # Google coverage; there is no other scraper for those sites.
#         jobspy: false                    # linkedin + indeed + google
