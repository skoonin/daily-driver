{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "allowedMcpServers": [{ "serverName": "playwright" }],
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(mkdir -p PLACEHOLDER_OUTPUT_DIR*)",
      "Bash(ls PLACEHOLDER_OUTPUT_DIR*)",
      "Bash(git -C PLACEHOLDER_OUTPUT_DIR*)",
      "Bash(bash scripts/*)",
      "Bash(echo \"current_time=*)",
      "Bash(echo '{\"completed_tickets*)",
      "Bash(OUTPUT_DIR=*)",
      "Bash(TODAY=*)",
      "Bash(DAYS_SINCE_MON=*)",
      "Bash(YEAR=*)",
      "Bash(PROJECTS=*)",
      "Bash(SEARCH_START=*)",
      "Bash(SAVE=*)",
      "Bash(yq *)",
      "Bash(cat PLACEHOLDER_STATE_DIR/*)",
      "Bash(date *)",
      "Bash(pbcopy)",

      "Bash(icalBuddy -f -ic \"Work\" eventsToday)",
      "Bash(icalBuddy -f eventsToday)"
    ],
    "additionalDirectories": ["PLACEHOLDER_HOME/git", "PLACEHOLDER_HOME/.claude", "/tmp", "PLACEHOLDER_OUTPUT_DIR"]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hook-current-time.sh"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": false
  }
}
